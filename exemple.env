# Telergam bot token
ConnectionStrings__Telegram=""

# Telergam Chat ID
AppOptions__FeedbackChatId=-111111111111

# Answer for start command
AppOptions__Start="Здравствуйте! Чем я могу вам помочь?"

# Enable data transfer if version 0.1.* was previously used 
Migrator__EnableMigratorFromV01=true

# Automatically apply database schema changes
Migrator__UpdateDatabase=true

# Enables forced culture installation for all users
AppOptions__OverrideCultureEnabled=false

# Specifies culture to force installation with AppOptions__OverrideCultureEnabled = true
AppOptions__OverrideCultureTag=ru-ru
